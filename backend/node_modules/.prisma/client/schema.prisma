generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id
  email             String   @unique
  password_hash     String
  profile_image_url String?
  full_name         String?
  role              String   @default("user")
  phone             String?
  bio               String?
  city              String?
  country           String?
  birthdate         String?
  gender            String?
  height            String?
  weight            String?
  hair_color        String?
  eye_color         String?
  clothing_size     String?
  shoe_size         String?
  skills            String?
  languages         String?
  experience        String?
  gallery           String?
  is_verified       Int      @default(0)
  verification_code String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("users")
}

model Project {
  id                    String   @id
  name                  String
  type                  String
  status                String
  short_description     String?
  full_description      String?
  image_url             String?
  production_company    String?
  director              String?
  location              String?
  shooting_start_date   String?
  shooting_end_date     String?
  daily_start_time      String?
  daily_end_time        String?
  slot_duration_minutes Int?
  project_gallery       String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("projects")
}

model CastingSlot {
  id         String   @id
  project_id String
  slot_date  String
  start_time String
  end_time   String
  status     String   @default("open")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("casting_slots")
}

model Position {
  id              String   @id
  project_id      String
  title           String
  description     String?
  location        String?
  shooting_date   String?
  compensation    String?
  spots_total     Int      @default(1)
  spots_filled    Int      @default(0)
  age_min         Int?
  age_max         Int?
  gender          String?
  required_skills String?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("positions")
}

model Application {
  id              String   @id
  project_id      String
  position_id     String
  slot_id         String?
  user_id         String?
  is_guest        Int      @default(0)
  applicant_name  String
  applicant_email String
  applicant_phone String?
  message         String?
  status          String   @default("pending")
  admin_notes     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("applications")
}

model Notification {
  id         String   @id
  user_id    String
  message    String
  read       Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("notifications")
}

model AuditLog {
  id          String   @id
  action      String
  entity_type String
  entity_id   String?
  details     String?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model ResetToken {
  token      String   @id
  email      String
  expires_at DateTime

  @@map("reset_tokens")
}
